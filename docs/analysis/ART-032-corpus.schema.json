{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://global-news-engine.local/schemas/art-032-corpus-1.0.json",
  "title": "ART-032 story evaluation corpus",
  "type": "object",
  "required": ["schemaVersion", "corpusVersion", "provenance", "articles", "pairs", "referenceStories", "baseline"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "corpusVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "provenance": {"type": "object"},
    "articles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ref", "urlHash", "canonicalUrl", "domain", "title", "titleInputHash", "firstSeenAt"],
        "properties": {
          "ref": {"type": "string", "pattern": "^article-[0-9a-f]{16}$"},
          "urlHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "canonicalUrl": {"type": "string", "format": "uri"},
          "domain": {"type": "string"},
          "title": {"type": "string", "minLength": 1},
          "titleInputHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "firstSeenAt": {"type": "string", "format": "date-time"},
          "publishedAt": {"type": "string", "format": "date-time"}
        },
        "additionalProperties": false
      }
    },
    "pairs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "left", "right", "label", "split", "category", "hardNegative", "rationale", "verification"],
        "properties": {
          "id": {"type": "string", "pattern": "^pair-[0-9a-f]{16}$"},
          "left": {"type": "string"},
          "right": {"type": "string"},
          "label": {"enum": ["SAME_STORY", "DIFFERENT_STORY", "UNCERTAIN"]},
          "split": {"enum": ["calibration", "evaluation"]},
          "category": {"type": "string"},
          "hardNegative": {"type": "boolean"},
          "rationale": {"type": "string", "minLength": 1},
          "verification": {
            "type": "object",
            "required": ["method", "checkedAt", "evidence"],
            "properties": {
              "method": {"type": "string"},
              "checkedAt": {"type": "string", "format": "date"},
              "evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "referenceStories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "split", "articleRefs", "rationale"],
        "properties": {
          "id": {"type": "string"},
          "split": {"enum": ["calibration", "evaluation"]},
          "articleRefs": {"type": "array", "minItems": 3, "items": {"type": "string"}},
          "rationale": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "baseline": {"type": "object"}
  },
  "additionalProperties": false
}
