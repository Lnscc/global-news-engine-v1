                  "pm.test('Fehlercode ist stabil', () => pm.expect(pm.response.json().code).to.eql('invalid_request'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Ungueltige Sortierrichtung ergibt 400",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/articles?direction=sideways",
              "host": ["{{baseUrl}}"],
              "path": ["articles"],
              "query": [{ "key": "direction", "value": "sideways" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status ist 400', () => pm.response.to.have.status(400));",
