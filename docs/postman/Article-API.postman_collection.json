    },
    {
      "name": "Extraction Health",
      "item": [
        {
          "name": "Extraction-Status abrufen",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/articles/extraction/health",
              "host": ["{{baseUrl}}"],
              "path": ["articles", "extraction", "health"]
            },
            "description": "Liefert Pending-Zeilen, erfolgreiche Signale, gruppierte Extraction-Errors und den letzten verarbeiteten Timestamp je Signaltyp sowie die Gesamtzahl der Artikel."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status ist 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response hat stabile Health-Felder', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.all.keys('articlesCreatedTotal', 'signalTypes');",
                  "  pm.expect(body.articlesCreatedTotal).to.be.a('number');",
                  "  pm.expect(body.signalTypes).to.be.an('array').with.lengthOf(3);",
                  "});",
                  "pm.test('Alle Signaltypen und Metriken sind vorhanden', () => {",
                  "  const signalTypes = pm.response.json().signalTypes;",
                  "  pm.expect(signalTypes.map(item => item.signalType)).to.have.members(['EVENTS', 'MENTIONS', 'GKG']);",
                  "  signalTypes.forEach(item => {",
                  "    pm.expect(item).to.have.all.keys('signalType', 'pendingStageRows', 'articleSignals', 'latestProcessedSourceTimestamp', 'extractionErrors');",
                  "    pm.expect(item.pendingStageRows).to.be.a('number');",
                  "    pm.expect(item.articleSignals).to.be.a('number');",
                  "    pm.expect(item.extractionErrors).to.be.an('array');",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Validierung",
      "item": [
        {
          "name": "Negativer Offset ergibt 400",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/articles?offset=-1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["articles"],
              "query": [
                { "key": "offset", "value": "-1" },
                { "key": "limit", "value": "20" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status ist 400', () => pm.response.to.have.status(400));",
                  "pm.test('Fehlercode ist stabil', () => pm.expect(pm.response.json().code).to.eql('invalid_request'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Zu grosses Limit ergibt 400",
          "request": {
