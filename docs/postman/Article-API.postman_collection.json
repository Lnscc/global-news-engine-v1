{
  "info": {
    "_postman_id": "33af713d-e32f-4a3d-939e-5bb0bb90d003",
    "name": "Global News Engine - Article API",
    "description": "Manuelle Tests fuer die REST-Endpunkte der Article API, einschliesslich Artikelsuche und Filter, nullable GKG-Titelmetadaten und Extraction Health.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Articles",
      "item": [
        {
          "name": "Artikel auflisten",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/articles?offset={{offset}}&limit={{pageLimit}}",
              "host": ["{{baseUrl}}"],
              "path": ["articles"],
              "query": [
                { "key": "offset", "value": "{{offset}}" },
                { "key": "limit", "value": "{{pageLimit}}" }
              ]
            },
            "description": "Liefert eine paginierte Artikelliste. Erlaubtes Limit: 1 bis 100."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status ist 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response hat stabile Page-Felder', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.all.keys('articles', 'offset', 'limit', 'total');",
                  "  pm.expect(body.articles).to.be.an('array');",
                  "  body.articles.forEach(article => {",
                  "    pm.expect(article).to.have.all.keys('id', 'canonicalUrl', 'domain', 'firstSeenAt', 'title', 'titleSource');",
                  "    pm.expect(article.title).to.satisfy(value => value === null || typeof value === 'string');",
                  "    pm.expect(article.titleSource).to.satisfy(value => value === null || typeof value === 'string');",
                  "  });",
                  "});",
                  "const body = pm.response.json();",
                  "if (body.articles.length > 0) {",
                  "  pm.environment.set('articleId', body.articles[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Artikeldetails abrufen",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/articles/{{articleId}}",
              "host": ["{{baseUrl}}"],
              "path": ["articles", "{{articleId}}"]
            },
            "description": "Verwendet articleId aus dem Environment. Der Listen-Request aktualisiert die Variable automatisch, wenn Artikel existieren."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status ist 200', () => pm.response.to.have.status(200));",
                  "pm.test('Detail enthaelt stabile Felder', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.all.keys('id', 'canonicalUrl', 'domain', 'firstSeenAt', 'title', 'titleSource', 'createdAt', 'updatedAt', 'signals');",
                  "  pm.expect(body.title).to.satisfy(value => value === null || typeof value === 'string');",
                  "  pm.expect(body.titleSource).to.satisfy(value => value === null || typeof value === 'string');",
                  "  pm.expect(body.signals).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Artikel suchen und filtern",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/articles?q=climate&domain=example.org&firstSeenFrom=2026-01-01T00:00:00Z&firstSeenTo=2027-01-01T00:00:00Z&theme=CLIMATE&signalType=GKG&direction=asc&offset=0&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["articles"],
              "query": [
                { "key": "q", "value": "climate" },
                { "key": "domain", "value": "example.org" },
                { "key": "firstSeenFrom", "value": "2026-01-01T00:00:00Z" },
                { "key": "firstSeenTo", "value": "2027-01-01T00:00:00Z" },
                { "key": "theme", "value": "CLIMATE" },
                { "key": "signalType", "value": "GKG" },
                { "key": "direction", "value": "asc" },
                { "key": "offset", "value": "0" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "Alle Filter sind optional und werden mit AND kombiniert. firstSeenFrom ist inklusiv, firstSeenTo exklusiv."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status ist 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response entspricht dem Page-Vertrag', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.all.keys('articles', 'offset', 'limit', 'total');",
                  "  pm.expect(body.articles).to.be.an('array');",
                  "  pm.expect(body.total).to.be.a('number');",
                  "});",
                  "pm.test('Ergebnisse erfuellen Domain und Zeitraum', () => {",
                  "  pm.response.json().articles.forEach(article => {",
                  "    pm.expect(article.domain).to.eql('example.org');",
                  "    pm.expect(new Date(article.firstSeenAt).getTime()).to.be.at.least(new Date('2026-01-01T00:00:00Z').getTime());",
                  "    pm.expect(new Date(article.firstSeenAt).getTime()).to.be.below(new Date('2027-01-01T00:00:00Z').getTime());",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Nicht vorhandener Artikel",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/articles/999999999",
              "host": ["{{baseUrl}}"],
              "path": ["articles", "999999999"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status ist 404', () => pm.response.to.have.status(404));"],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
